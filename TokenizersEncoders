# Loss function (uses learnable logit_scale)
def clip_loss(image_embeds, text_embeds, logit_scale_param):
    image_embeds = F.normalize(image_embeds, dim=1)
    text_embeds = F.normalize(text_embeds, dim=1)
    scale = logit_scale_param.exp()
    logits = (image_embeds @ text_embeds.T) * scale
    labels = torch.arange(logits.size(0), device=logits.device)
    loss_i2t = nn.CrossEntropyLoss()(logits, labels)
    loss_t2i = nn.CrossEntropyLoss()(logits.T, labels)
    return (loss_i2t + loss_t2i) / 2
